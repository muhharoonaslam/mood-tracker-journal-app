modules = ["nodejs-20", "dotnet-7.0", "web", "php-8.2", "dotnet-8.0"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PHP Summary"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd mood-tracker-api && dotnet bin/Release/net8.0/MoodTrackerApi.dll"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd mood-tracker-frontend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "PHP Summary"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "php -S 0.0.0.0:8080 summary.php"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd mood-tracker-api/out && dotnet MoodTrackerApi.dll & until curl -sf http://localhost:8000/swagger/index.html > /dev/null 2>&1; do sleep 1; done && node /home/runner/workspace/server.js"]
build = ["bash", "-c", "cd mood-tracker-api && dotnet publish -c Release -o out && cd ../mood-tracker-frontend && npm install && npm run build && cd .. && npm install --omit=dev"]
